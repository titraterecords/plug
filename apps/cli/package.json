{
  "name": "@titrate/plug",
  "version": "0.3.1",
  "type": "module",
  "bin": {
    "plug": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "knip": "echo 'Run knip from repo root (pnpm knip)'",
    "lint": "eslint . --fix",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@titrate/registry-schema": "workspace:*",
    "eslint": "^9.22.0",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
