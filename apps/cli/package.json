  "devDependencies": {
    "eslint": "^9.22.0",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
